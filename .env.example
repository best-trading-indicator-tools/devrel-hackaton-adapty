# OpenAI credentials (use your Codex/OAuth-backed token or API key)
OPENAI_API_KEY=
# OpenAI Codex OAuth (preferred for gpt-5.3-codex)
# OPENAI_OAUTH_TOKEN=
# OPENAI_OAUTH_REFRESH_TOKEN=
# OPENAI_OAUTH_ACCOUNT_ID=
# Optional Unix seconds or ms epoch for expiry; if omitted, token exp is read from JWT
# OPENAI_OAUTH_EXPIRES_AT=
# Optional fallback naming used in some setups
# OPENAI_ACCESS_TOKEN=

# Generation model
OPENAI_MODEL=gpt-5.3-codex
# Optional fallback if the requested model is unavailable on your account
OPENAI_MODEL_FALLBACK=gpt-5.2
# Chart image companion model (OpenAI Images API)
OPENAI_IMAGE_MODEL=gpt-image-1.5
# Optional custom OpenAI-compatible endpoint for API-key mode
# OPENAI_BASE_URL=http://127.0.0.1:18789/v1
# Optional Codex responses endpoint base (defaults to chatgpt.com backend)
# OPENAI_CODEX_BASE_URL=https://chatgpt.com/backend-api

# Optional Memegen base URL (set this when self-hosting Memegen)
# MEMEGEN_BASE_URL=https://api.memegen.link

# Optional web fact-check settings (Brave Search)
# ENABLE_WEB_FACT_CHECK=true
# BRAVE_SEARCH_API_KEY=
# Optional cap for total snippets added to prompt
# WEB_FACT_CHECK_MAX_RESULTS=4

# Optional RSS industry news context settings (for "Industry news reaction")
# ENABLE_RSS_INDUSTRY_NEWS=true
# RSS_NEWS_MAX_AGE_DAYS=7
# RSS_NEWS_TOP_ITEMS=4
# RSS_NEWS_CACHE_TTL_SECONDS=600
# RSS_NEWS_FEED_TIMEOUT_MS=4500

# Optional SOIS benchmark context settings (for analysis-heavy post types)
# ENABLE_SOIS_CONTEXT=true
# SOIS_DATA_URL=https://dags.adpinfra.dev/webhook/sois-data
# SOIS_DATA_USERNAME=
# SOIS_DATA_PASSWORD=

# Embedding retrieval settings
ENABLE_LANCEDB=false
# Cost/speed default. For best semantic retrieval quality, use text-embedding-3-large.
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Optional dedicated embedding endpoint when needed
# OPENAI_EMBEDDING_BASE_URL=
