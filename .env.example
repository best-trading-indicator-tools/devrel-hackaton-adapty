# OpenAI credentials (use your Codex/OAuth-backed token or API key)
OPENAI_API_KEY=
# Optional alternatives if you prefer naming tokens differently
# OPENAI_OAUTH_TOKEN=
# OPENAI_ACCESS_TOKEN=

# Generation model
OPENAI_MODEL=gpt-5.3-codex
# Optional fallback if the requested model is unavailable on your account
OPENAI_MODEL_FALLBACK=gpt-5.2
# Optional custom OpenAI-compatible endpoint (e.g. OpenClaw Gateway)
# OPENAI_BASE_URL=http://127.0.0.1:18789/v1

# Embedding retrieval settings
ENABLE_LANCEDB=false
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
